   1          #include "user_uart.h"
   2          
   3          //激活p30和p31引脚
   4          //gpio
   5          void uart_gpio_init(){
   6   1        // tx P30 rx P31
   7   1        GPIO_InitTypeDef uart_gpio;
   8   1        uart_gpio.Mode = GPIO_PullUp;
   9   1        uart_gpio.Pin = GPIO_Pin_0 | GPIO_Pin_1;
  10   1        
  11   1        GPIO_Inilize(GPIO_P3, &uart_gpio);
  12   1      }
  13          
  14          //激活p30和p31的串口功能
  15          //uart
  16          void user_uart_init(){
  17   1        
  18   1        COMx_InitDefine user_uart;
  19   1        
  20   1        user_uart.UART_Mode  = UART_8bit_BRTx;      //模式,         UART_ShiftRight,UART_8bit_BRTx,UART_9bit,UART_9b
             -it_BRTx
  21   1        user_uart.UART_BRT_Use = BRT_Timer1;    //使用波特率,   BRT_Timer1,BRT_Timer2,BRT_Timer3,BRT_Timer4
  22   1        user_uart.UART_BaudRate = 115200; //9600  //波特率,      一般 110 ~ 115200
  23   1        //115200 8个电平跳变+1开始位+结束位置 = 10位
  24   1        //11.25kb/s
  25   1        user_uart.Morecommunicate = DISABLE;  //多机通讯允许, ENABLE,DISABLE
  26   1        user_uart.UART_RxEnable = ENABLE;   //允许接收,   ENABLE,DISABLE
  27   1        user_uart.BaudRateDouble = DISABLE;   //波特率加倍, ENABLE,DISABLE
  28   1      
  29   1        UART_Configuration(UART1, &user_uart);
  30   1        
  31   1        //中断开关
  32   1        NVIC_UART1_Init(ENABLE,Priority_1);
  33   1        
  34   1        //把引脚从gpio功能切换成uart功能
  35   1        UART1_SW(UART1_SW_P30_P31);
  36   1      }
  37          
  38          void user_uart_all_init(){
  39   1        uart_gpio_init();
  40   1        user_uart_init();
