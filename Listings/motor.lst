  21   1        if(state == ENABLE){
  22   2          motor_pwma.PWM_CEN_Enable = ENABLE;   //使能计数器, ENABLE,DISABLE
  23   2          motor_pwma.PWM_MainOutEnable = ENABLE;//主输出使能,  ENABLE,DISABLE
  24   2        }else if(state == DISABLE){
  25   2          motor_pwma.PWM_CEN_Enable = DISABLE;    //使能计数器, ENABLE,DISABLE
  26   2          motor_pwma.PWM_MainOutEnable = DISABLE;//主输出使能,  ENABLE,DISABLE
  27   2      
  28   2        }
  29   1          PWM_Configuration(PWMA, &motor_pwma);
  30   1      }
